rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Players — users can only read/write their own document
    match /artifacts/{appId}/public/data/tradewars_players/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Universe — all authenticated users can read, only admins can write
    match /artifacts/{appId}/public/data/tradewars_universe/{docId} {
      allow read: if request.auth != null;
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                   && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // NPCs — all authenticated users can read, only admins can write
    match /artifacts/{appId}/public/data/tradewars_npcs/{docId} {
      allow read: if request.auth != null;
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                   && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Events — all authenticated users can read, only admins can write
    match /artifacts/{appId}/public/data/tradewars_events/{docId} {
      allow read: if request.auth != null;
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                   && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Companies — authenticated users can read all, write only their own membership
    match /artifacts/{appId}/public/data/tradewars_companies/{companyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['members', 'treasury']);
    }

    // Admins — read-only for auth check, never client-writable (seed via Firebase Console)
    match /admins/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if false;
    }
  }
}
